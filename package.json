{
  "name": "mt-formatter",
  "displayName": "Swift MT Message Formatter",
  "description": "Format, validate, and explore SWIFT MT financial messages — field-by-field with hover docs, real-time validation, and 130+ field definitions",
  "version": "0.1.0",
  "publisher": "mt-formatter",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/hameedibrh/mt-formatter"
  },
  "bugs": {
    "url": "https://github.com/hameedibrh/mt-formatter/issues"
  },
  "homepage": "https://github.com/hameedibrh/mt-formatter#readme",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Formatters", "Linters", "Programming Languages"],
  "keywords": ["swift", "mt", "financial", "banking", "MT103", "MT202", "MT940", "payments", "SWIFT MT"],
  "galleryBanner": {
    "color": "#0F2027",
    "theme": "dark"
  },
  "activationEvents": ["onLanguage:swift-mt"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "swift-mt",
        "aliases": ["Swift MT", "MT Message", "SWIFT MT"],
        "extensions": [".mtswift"],
        "configuration": "./language-configuration.json",
        "firstLine": "^\\{1:"
      }
    ],
    "grammars": [
      {
        "language": "swift-mt",
        "scopeName": "source.swift-mt",
        "path": "./syntaxes/mt.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "mt-formatter.formatDocument",
        "title": "Format MT Message",
        "category": "MT"
      },
      {
        "command": "mt-formatter.showMessageInfo",
        "title": "Show MT Message Info",
        "category": "MT"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "mt-formatter.formatDocument",
          "when": "editorLangId == swift-mt",
          "group": "1_modification"
        },
        {
          "command": "mt-formatter.showMessageInfo",
          "when": "editorLangId == swift-mt",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
