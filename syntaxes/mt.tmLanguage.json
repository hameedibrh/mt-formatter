{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Swift MT Message",
  "scopeName": "source.swift-mt",
  "patterns": [
    { "include": "#block4" },
    { "include": "#block1" },
    { "include": "#block2" },
    { "include": "#block3" },
    { "include": "#block5" }
  ],
  "repository": {
    "block1": {
      "name": "meta.block.basic-header.swift-mt",
      "match": "^(\\{)(1:)([FLT])(01)([A-Z]{4}[A-Z]{2}[A-Z0-9]{2}[A-Z0-9]{0,3})([0-9]{4})([0-9]{6})(\\})",
      "captures": {
        "1": { "name": "punctuation.definition.block.swift-mt" },
        "2": { "name": "entity.name.block-id.swift-mt" },
        "3": { "name": "constant.character.application-id.swift-mt" },
        "4": { "name": "constant.numeric.service-id.swift-mt" },
        "5": { "name": "entity.name.bic.swift-mt" },
        "6": { "name": "constant.numeric.session.swift-mt" },
        "7": { "name": "constant.numeric.sequence.swift-mt" },
        "8": { "name": "punctuation.definition.block.swift-mt" }
      }
    },
    "block2": {
      "name": "meta.block.app-header.swift-mt",
      "begin": "^(\\{)(2:)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.block.swift-mt" },
        "2": { "name": "entity.name.block-id.swift-mt" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.block.swift-mt" }
      },
      "patterns": [
        {
          "match": "([IO])(\\d{3})",
          "captures": {
            "1": { "name": "keyword.control.direction.swift-mt" },
            "2": { "name": "entity.name.mt-type.swift-mt" }
          }
        },
        {
          "match": "[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}[A-Z0-9]{0,3}",
          "name": "entity.name.bic.swift-mt"
        },
        {
          "match": "[0-9]+",
          "name": "constant.numeric.swift-mt"
        }
      ]
    },
    "block3": {
      "name": "meta.block.user-header.swift-mt",
      "begin": "^(\\{)(3:)",
      "end": "(\\}(?!\\}))",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.block.swift-mt" },
        "2": { "name": "entity.name.block-id.swift-mt" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.block.swift-mt" }
      },
      "patterns": [
        { "include": "#subfield" }
      ]
    },
    "block4": {
      "name": "meta.block.text.swift-mt",
      "begin": "^(\\{)(4:)\\s*$",
      "end": "^(-\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.block.swift-mt" },
        "2": { "name": "entity.name.block-id.swift-mt" }
      },
      "endCaptures": {
        "1": { "name": "keyword.control.block-terminator.swift-mt" }
      },
      "patterns": [
        { "include": "#field" }
      ]
    },
    "block5": {
      "name": "meta.block.trailer.swift-mt",
      "begin": "^(\\{)(5:)",
      "end": "(\\}(?!\\}))",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.block.swift-mt" },
        "2": { "name": "entity.name.block-id.swift-mt" }
      },
      "endCaptures": {
        
        "1": { "name": "punctuation.definition.block.swift-mt" }
      },
      "patterns": [
        { "include": "#subfield" }
      ]
    },
    "field": {
      "patterns": [
        {
          "name": "meta.field.swift-mt",
          "match": "^(:[0-9]{2}[A-Z]?:)(.*$)",
          "captures": {
            "1": { "name": "keyword.operator.field-tag.swift-mt" },
            "2": {
              "patterns": [
                { "include": "#amount" },
                { "include": "#date6" },
                { "include": "#currency" },
                { "include": "#bic" },
                { "include": "#fieldValue" }
              ]
            }
          }
        },
        {
          "name": "string.unquoted.continuation.swift-mt",
          "match": "^(?!:[0-9]{2}[A-Z]?:)(?!-\\})(.+)$"
        }
      ]
    },
    "subfield": {
      "name": "meta.subfield.swift-mt",
      "begin": "(\\{)(\\d{3}:)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.subfield.swift-mt" },
        "2": { "name": "keyword.operator.subfield-tag.swift-mt" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.subfield.swift-mt" }
      },
      "patterns": [
        { "match": "[^}]+", "name": "string.unquoted.subfield-value.swift-mt" }
      ]
    },
    "amount": {
      "match": "\\d{1,15}(,\\d{1,2})?(?=[A-Z]|\\s|$)",
      "name": "constant.numeric.amount.swift-mt"
    },
    "date6": {
      "match": "\\b[0-9]{6}\\b",
      "name": "constant.other.date.swift-mt"
    },
    "currency": {
      "match": "\\b[A-Z]{3}\\b",
      "name": "constant.language.currency.swift-mt"
    },
    "bic": {
      "match": "\\b[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}([A-Z0-9]{3})?\\b",
      "name": "entity.name.bic.swift-mt"
    },
    "fieldValue": {
      "match": ".+",
      "name": "string.unquoted.field-value.swift-mt"
    }
  }
}
